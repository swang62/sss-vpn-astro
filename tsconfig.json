{
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "verbatimModuleSyntax": false,
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "extends": "astro/tsconfigs/strict"
}
