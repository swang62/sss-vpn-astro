---
import { Icon } from "astro-icon/components";
import { cn } from "@/lib/utils";

const features = [
  {
    description:
      "Almost all commercial VPN services are banned or extremely unreliable in China despite their claims. The fact that this VPN actually works is its biggest feature.",
    icon: "lucide:biceps-flexed",
    title: "Actually works",
    wide: true,
  },
  {
    description:
      "Tech support from someone who is using the same VPN as you every day. Any downtime is unacceptable.",
    icon: "lucide:heart-handshake",
    title: "Unbeatable service",
    wide: false,
  },
  {
    description:
      "Everything hosted on my own private servers. If the server gets banned, I can spin up another one in no time.",
    icon: "lucide:shield-check",
    title: "Ban-proof",
    wide: false,
  },
  {
    description:
      "Supports all desktop and mobile platforms. Latest obfuscation protocols like X-ray, Vless, Vmess, Reality, Trojan, Hysteria, Shadowsocks, etc.",
    icon: "lucide:globe-lock",
    title: "Details",
    wide: true,
  },
];
---

<section id="features" class="py-section-gap-sm md:py-section-gap-lg">
  <div class="container max-w-6xl">
    <div class="mb-12 flex flex-col items-center text-center sm:mb-16">
      <h2
        class="font-heading text-3xl leading-[1.08] text-balance md:text-4xl lg:text-[40px]"
      >
        What makes this VPN unique?
      </h2>
    </div>

    <div class="grid grid-cols-1 gap-5 md:grid-cols-12 md:gap-6">
      {
        features.map((f) => (
          <div
            class={cn(
              "group relative overflow-hidden rounded-2xl border border-border bg-card p-6 sm:p-8",
              f.wide ? "md:col-span-7" : "md:col-span-5",
            )}
          >
            <div
              aria-hidden="true"
              class={cn(
                "absolute inset-0 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100 bg-linear-to-br",
                f.wide ? "from-primary/10" : "from-secondary/10",
              )}
            />
            <div class="relative">
              <div class="mb-3 flex items-center gap-3 sm:mb-4">
                <div class="flex size-12 shrink-0 items-center justify-center rounded-xl border border-border bg-background">
                  <Icon
                    name={f.icon}
                    class={`size-5 ${f.wide ? "text-primary" : "text-secondary"}`}
                  />
                </div>
                <h3 class="font-heading text-lg sm:text-xl">{f.title}</h3>
              </div>
              <p class="text-muted-foreground leading-relaxed">
                {f.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
