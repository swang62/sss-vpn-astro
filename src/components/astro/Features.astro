---
import { Icon } from "astro-icon/components";
import { cn } from "@/lib/utils";

const features = [
  {
    description:
      "Almost all commercial VPN services are banned or extremely unreliable in high-censorship countries like China, Iran, Russia (despite their claims). The fact that this VPN actually works is its biggest feature.",
    icon: "lucide:biceps-flexed",
    title: "It actually works",
    wide: true,
  },
  {
    description:
      "Personal customer support from someone who is using the same VPN every day. Any downtime will be addressed immediately.",
    icon: "lucide:heart-handshake",
    title: "Unbeatable customer service",
    wide: false,
  },
  {
    description:
      "Everything is hosted on my own private cloud servers. If the server gets banned, I can spin up another one instantly.",
    icon: "lucide:shield-check",
    title: "Resilient against bans",
    wide: false,
  },
  {
    description:
      "Supports all desktop and mobile platforms. Latest obfuscation protocols include X-ray, Vless, Vmess, Reality, Trojan, Hysteria, Shadowsocks, and more...",
    icon: "lucide:globe-lock",
    title: "Technical details",
    wide: true,
  },
];
---

<section id="features" class="py-section-gap-lg">
  <div class="container max-w-6xl">
    <div class="flex flex-col items-center text-center mb-16">
      <h2 class="font-heading text-3xl text-balance md:text-4xl lg:text-[40px]">
        What makes this VPN unique?
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      {
        features.map((f) => (
          <div
            class={cn(
              "group relative overflow-hidden rounded-2xl border border-border bg-card p-8",
              f.wide ? "md:col-span-7" : "md:col-span-5",
            )}
          >
            <div
              aria-hidden="true"
              class={cn(
                "absolute inset-0 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100 bg-linear-to-br",
                f.wide ? "from-primary/10" : "from-secondary/10",
              )}
            />
            <div class="relative">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex size-12 shrink-0 items-center justify-center rounded-xl border border-border bg-background">
                  <Icon
                    name={f.icon}
                    class={`size-5 ${f.wide ? "text-primary" : "text-secondary"}`}
                  />
                </div>
                <h3 class="font-heading text-xl">{f.title}</h3>
              </div>
              <p class="text-muted-foreground leading-relaxed">
                {f.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
