---
import { Icon } from "astro-icon/components";
import StatusBadge from "@/components/StatusBadge";
import ConnectButton from "@/components/ConnectButton";
---

<section
  id="top"
  class="relative min-h-[90vh] flex items-center justify-center overflow-hidden"
>
  <div
    class="relative z-10 flex flex-col items-center gap-6 px-4 text-center max-w-5xl"
  >
    <StatusBadge client:load />
    <h1
      class="font-heading text-4xl text-balance sm:text-5xl md:text-6xl lg:text-[66px] leading-tight"
    >
      Welcome to Steve's{" "}
      <span class="animated-gradient-text font-extrabold">
        {" "}
        Super Secret VPN{" "}
      </span>
    </h1>

    <p
      class="text-muted-foreground max-w-xl leading-normal pb-4 text-balance sm:text-xl sm:leading-8"
    >
      Creative name I know... but if you're here, then you already know what's
      up
      <Icon
        name="mdi:face-cool"
        class="text-primary mb-1 ml-1 inline-block size-6"
      />
    </p>

    <ConnectButton client:load />
  </div>
</section>
