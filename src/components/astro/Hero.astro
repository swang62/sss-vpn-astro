---
import { Icon } from "astro-icon/components";
import { ArrowRight } from "lucide-react";

import { Button } from "@/components/ui/button";
---

<section id="top" class="py-16 md:py-24">
  <div class="container flex max-w-5xl flex-col items-center gap-6 text-center">
    <h1
      class="font-heading text-4xl text-balance sm:text-5xl md:text-6xl lg:text-[66px]"
    >
      Welcome to Steve's {" "}
      <span class="text-gradient font-extrabold"> Super Secret VPN </span>
    </h1>

    <p
      class="text-muted-foreground max-w-xl leading-normal text-balance sm:text-xl sm:leading-8"
    >
      Creative name I know... but if you're here, then you already know what's
      up <Icon
        name="mdi:face-cool"
        class="text-primary mb-1 inline-block size-6"
      />
    </p>

    <div class="flex justify-center">
      <a href="/signup">
        <Button className="rounded-full" data-umami-event="get-started">
          Get started for free
          <ArrowRight className="size-6" />
        </Button>
      </a>
    </div>
  </div>
</section>
