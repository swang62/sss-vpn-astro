---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { IS_PRODUCTION } from "@/lib/env";
import "../styles/500.css";
import Sign from "/toaster.svg?raw";

export const prerender = false;

interface Props {
  error: unknown;
}

const { error: _error } = Astro.props;
const error = _error as Error;
---

<BaseLayout title="Oh No! | SSS-VPN">
  <a
    href="/"
    class="font-roboto-thin m-auto flex h-[100vh] w-full flex-col items-center justify-center px-0 md:px-12"
  >
    <Fragment set:html={Sign} />
    <h1 class="error-title text-2xl md:text-4xl">
      <span class="font-roboto text-5xl text-orange-200">Woops!</span>
      <br />
      Time to fix the toaster...
    </h1>
  </a>

  <!-- Add the stack trace ONLY during development -->
  {
    !IS_PRODUCTION && (
      <div class="instructions flex flex-col gap-4">
        <div class="text-2xl font-thin">Details</div>
        <code>{JSON.stringify(error, null, 2)}</code>
      </div>
    )
  }
</BaseLayout>
