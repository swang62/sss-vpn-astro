---
import BaseLayout from "@/layouts/BaseLayout.astro";
import "@/styles/500.css";
import Sign from "/toaster.svg?raw";

export const prerender = true;

interface Props {
  error: unknown;
}

const { error } = Astro.props;
---

<BaseLayout title="Oh No!">
  <a
    href="/"
    class="m-auto flex h-[100vh] w-full flex-col items-center justify-center px-0 md:px-12"
  >
    <Fragment set:html={Sign} />
    <h1 class="error-title text-2xl md:text-4xl">
      <span class="font-serif text-5xl text-orange-200">Woops!</span>
      <br />
      Time to fix the toaster...
    </h1>
  </a>

  <div class="instructions flex flex-col gap-4">
    <div class="text-2xl font-thin">Details</div>
    <code>{JSON.stringify(error, null, 2)}</code>
  </div>
</BaseLayout>
