---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Sign from "/toaster.svg?raw";

export const prerender = true;

interface Props {
  error: unknown;
}

const { error } = Astro.props;
---

<BaseLayout title="Oh No!">
  <main class="container max-w-screen-md">
    <a
      href="/"
      class="m-auto flex h-[100vh] w-full flex-col items-center justify-center px-0 md:px-12"
    >
      <Fragment set:html={Sign} />
      <h1 class="mt-4 text-center text-2xl md:text-4xl">
        <span class="font-serif text-5xl text-orange-200">Woops!</span>
        <br />
        <br />
        Time to fix the toaster...
      </h1>
    </a>
  </main>
</BaseLayout>
