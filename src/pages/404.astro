---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Sign from "/hand-sign.svg?raw";
---

<BaseLayout title="Not Found | SSS-VPN">
  <a href="/" class="flex h-[90vh] w-full items-center justify-center">
    <Fragment set:html={Sign} />
  </a>
</BaseLayout>

<style>
  #error {
    margin: auto;
    display: block;
  }
</style>
<script>
  // eslint-disable-next-line ts/ban-ts-comment
  // @ts-nocheck
  window.onload = function () {
    var timer;
    var error = Snap.select("#error");
    var hole = Snap.select("#svg-hole");
    var hand = Snap.select("#svg-hand");
    var mask = Snap.select("#svg-mask");

    function onSVGLoaded() {
      function animOn() {
        hand.animate(
          {
            transform: "t10,-300, r0",
          },
          4500,
          mina.easeinout,
          animOut
        );

        mask.animate(
          {
            transform: "t-10,300, r0",
          },
          4500,
          mina.easeinout
        );
      }

      function animOut() {
        hand.animate(
          {
            transform: "t-10,-305, r0",
          },
          4500,
          mina.easeinout,
          animOn
        );

        mask.animate(
          {
            transform: "t10,305, r0",
          },
          4500,
          mina.easeinout
        );
      }

      function open() {
        clearTimeout(timer);
        hand.animate(
          {
            transform: "t0,-300",
          },
          800,
          mina.backout,
          animOn
        );

        mask.animate(
          {
            transform: "t0,300",
          },
          800,
          mina.backout
        );
      }

      timer = setTimeout(open, 1000);

      hand.attr({
        mask: mask,
      });
    }

    onSVGLoaded();
  };
</script>
