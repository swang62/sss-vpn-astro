---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Sign from "/hand-sign.svg?raw";

export const prerender = true;
---

<BaseLayout title="Not Found">
  <main class="container max-w-screen-md">
    <a
      href="/"
      class="mt-10 flex h-[100vh] w-full items-center justify-center sm:p-20"
    >
      <Fragment set:html={Sign} />
    </a>
  </main>
</BaseLayout>

<script src="/snapsvg.js" is:inline></script>
<script>
  // @ts-nocheck
  window.onload = function () {
    let timer;
    const hand = Snap.select("#svg-hand");
    const mask = Snap.select("#svg-mask");

    function onSVGLoaded() {
      function animOn() {
        hand.animate(
          {
            transform: "t10,-300, r0",
          },
          4500,
          mina.easeinout,
          animOut
        );

        mask.animate(
          {
            transform: "t-10,300, r0",
          },
          4500,
          mina.easeinout
        );
      }

      function animOut() {
        hand.animate(
          {
            transform: "t-10,-305, r0",
          },
          4500,
          mina.easeinout,
          animOn
        );

        mask.animate(
          {
            transform: "t10,305, r0",
          },
          4500,
          mina.easeinout
        );
      }

      function open() {
        clearTimeout(timer);
        hand.animate(
          {
            transform: "t0,-300",
          },
          800,
          mina.backout,
          animOn
        );

        mask.animate(
          {
            transform: "t0,300",
          },
          800,
          mina.backout
        );
      }

      timer = setTimeout(open, 1000);

      hand.attr({
        mask,
      });
    }

    onSVGLoaded();
  };
</script>
