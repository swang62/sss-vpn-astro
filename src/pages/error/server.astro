---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { apiServer } from "@/server/backend";
import { sleep } from "@/server/utils";

export const prerender = false;

setTimeout(async () => {
  await apiServer.error.$get();
  await sleep(1000);
  // @ts-expect-error
  fake_function(fake_variable);
}, 1000);
---

<BaseLayout title="Error">
  <div class="flex h-[90vh] items-center justify-center">
    <h1 id="error">Server error in 3...2...1...</h1>
  </div>
</BaseLayout>
