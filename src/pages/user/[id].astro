---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { apiServer } from "@/server/backend";
import { parsedApi } from "@/server/utils";

const { id = "" } = Astro.params;
const { data } = await parsedApi(
  apiServer.user[":id"].$get({
    param: { id },
  })
);
---

<BaseLayout title="User">
  <main class="container">
    <div class="flex flex-col gap-4">
      <div class="text-2xl">PATH: /user/{id}</div>
      {
        user ? (
          <code>{JSON.stringify(user, null, 2)}</code>
        ) : (
          <code>User {id} not found</code>
        )
      }
    </div>
  </main>
</BaseLayout>
