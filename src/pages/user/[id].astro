---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { apiServer } from "@/server/backend";

const { id = "" } = Astro.params;

const response = await apiServer.user[":id"].$get({
  param: { id },
});
const { user } = await response.json();
---

<BaseLayout title="User">
  <div class="instructions flex flex-col gap-4">
    <div class="text-2xl font-thin">PATH: /user/{id}</div>
    {
      user ? (
        <code>{JSON.stringify(user, null, 2)}</code>
      ) : (
        <code>User {id} not found</code>
      )
    }
  </div>
</BaseLayout>
