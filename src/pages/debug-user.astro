---
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import MainLayout from "@/layouts/MainLayout.astro";
import { apiServer } from "@/server/backend";
import { createForm } from "simple:form";
import z from "zod";

const now = new Date().toLocaleString();

let user = "";
const form = createForm({
  id: z.string().min(1),
});

const res = await Astro.locals.form.getData(form);
if (res?.data) {
  const response = await apiServer.user[":id"].$get({
    param: { id: res.data.id },
  });
  const data = await response.json();
  user = JSON.stringify(data, null, 2);
}

const hasError = res?.fieldErrors;
---

<MainLayout>
  <div class="flex flex-col gap-4 py-4 min-h-screen w-full">
    <form
      method="POST"
      class="flex flex-start gap-2"
      transition:persist="form-id"
    >
      <Button type="submit" variant="secondary" className="px-8">Search</Button>
      <Input
        id="id"
        autoComplete="off"
        placeholder="User ID"
        {...form.inputProps.id}
      />
      <a href="/debug">
        <Button variant="link">Check API</Button>
      </a>
    </form>

    <code id="code">{user || (hasError ? hasError.id : null)}</code>

    <div class="text-sm italic">Updated: {now}</div>
  </div>
</MainLayout>
