---
import PricingPlans from "@/components/PricingPlans";
import DashboardLayout from "@/layouts/DashboardLayout.astro";
---

<DashboardLayout title="Plans">
  <div class="container mx-auto flex w-full flex-col py-4">
    <div class="flex flex-col items-center pt-4 text-center">
      <h2 class="font-heading text-3xl md:text-4xl">Plans</h2>
      <hr class="border-border mt-2 w-32 border-t pt-2" />
    </div>

    <PricingPlans client:load />
  </div>
</DashboardLayout>
