---
import PricingForm from "@/components/PricingForm";
import DashboardLayout from "@/layouts/DashboardLayout.astro";
---

<DashboardLayout title="Plans">
  <div class="container flex flex-col w-full min-h-screen py-4 mx-auto">
    <div class="flex flex-col items-center pt-4 text-center">
      <h2 class="text-3xl font-heading sm:text-4xl md:text-5xl">Plans</h2>
      <hr class="w-32 pt-2 mt-2 border-t border-border" />
    </div>

    <PricingForm client:load />
  </div>
</DashboardLayout>
