---
import HowToInstall from "@/components/HowToInstall";
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import SubHeader from "@/layouts/SubHeader.astro";
import { UAParser } from "ua-parser-js";

const { session } = Astro.locals;

const userAgent = new UAParser(session?.userAgent);
const device = userAgent.getDevice().type;
const os = userAgent.getOS().name;
---

<DashboardLayout title="Dashboard">
  <div class="flex flex-col w-full max-w-2xl gap-6 py-4 mx-auto">
    <SubHeader title="How to Install" />
    <HowToInstall device={device} os={os} client:load />
  </div>
</DashboardLayout>
