---
import { UAParser } from "ua-parser-js";

import ApiStatus from "@/components/ApiStatus";
import DashboardLayout from "@/layouts/DashboardLayout.astro";

const { origin, pathname } = Astro.url;
const { session } = Astro.locals;
const device = UAParser(session?.userAgent || "");
---

<DashboardLayout title="Debug">
  <div class="flex flex-col w-full max-w-2xl gap-6 py-4 mx-auto">
    <ApiStatus
      device={device}
      pathname={pathname}
      origin={origin}
      client:load
    />
  </div>
</DashboardLayout>
