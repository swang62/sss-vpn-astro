---
import AccountDetails from "@/components/AccountDetails";
import AccountLinks from "@/components/AccountLinks";
import AccountPortal from "@/components/AccountPortal";
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import SubHeader from "@/layouts/SubHeader.astro";
---

<DashboardLayout title="Account">
  <div class="flex flex-col w-full max-w-2xl min-h-screen gap-6 py-4 mx-auto">
    <SubHeader title="Account" />
    <AccountDetails client:load />
    <AccountLinks client:load />
    <AccountPortal client:load />
  </div>
</DashboardLayout>
