---
import { PUBLIC_GTM_ID } from "@/config/client";
import { SEO } from "astro-seo";
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<meta name="viewport" content="width=device-width" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<SEO
  title={title}
  titleTemplate="%s | SSS-VPN"
  titleDefault="SSS-VPN"
  description="Steve's Super Secret VPN"
  openGraph={{
    basic: {
      title: "Steve's Super Secret VPN",
      type: "VPN SaaS",
      image: "/favicon.svg",
    },
  }}
/>

<!-- Custom scripts -->
{
  PUBLIC_GTM_ID && (
    <script
      is:inline
      defer
      src="https://umami.mildlybrewed.com/script.js"
      data-website-id={PUBLIC_GTM_ID}
    />
  )
}
