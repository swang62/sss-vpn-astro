---
import { SITE_NAME } from "@/config/constants";
import { cn } from "@/lib/utils";
import { GlobeLock } from "lucide-react";
---

<header
  class={cn(
    "flex items-center h-16 z-50 sticky top-0 border-b-[1px] bg-background dark:border-b-slate-700"
  )}
>
  <div class="container relative flex w-full items-center justify-between">
    <div class="flex w-full items-center gap-6 md:gap-8 lg:gap-10">
      <!-- left side  -->
      <a href="/" class="hidden items-center space-x-2 md:flex">
        <GlobeLock />
        <span class="text-nowrap text-xl font-bold sm:inline-block">
          {SITE_NAME}
        </span>
      </a>

      <!-- mobile only -->
      <slot name="mobile-menu" />

      <!-- center -->
      <div class="hidden md:flex">
        <slot name="center-header" />
      </div>
    </div>

    <!-- right side  -->
    <slot name="right-header" />
  </div>
</header>
