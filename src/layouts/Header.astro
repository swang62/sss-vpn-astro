---
import { SITE_NAME } from "@/config/constants";
import { cn } from "@/lib/utils";
import { Image } from "astro:assets";
---

<header
  class={cn(
    "flex items-center h-16 z-50 sticky top-0 border-b-[1px] dark:border-b-slate-700 bg-background"
  )}
>
  <div class="container relative flex w-full items-center justify-between">
    <div class="flex w-full gap-6 md:gap-8 lg:gap-10">
      <!-- mobile only -->
      <slot name="mobile-menu" />

      <!-- left side  -->
      <a href="/#top" class="hidden items-center space-x-2 md:flex">
        <Image
          src="/favicon.ico"
          class="text-foreground"
          alt="logo"
          width={32}
          height={32}
          loading="eager"
        />
        <span class="text-nowrap text-xl font-bold md:inline-block">
          {SITE_NAME}
        </span>
      </a>

      <!-- center -->
      <div class="hidden md:flex">
        <slot name="center-header" />
      </div>
    </div>

    <!-- right side  -->
    <slot name="right-header" />
  </div>
</header>
