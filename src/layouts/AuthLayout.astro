---
import { ClientRouter } from "astro:transitions";
import "sonner/dist/styles.css";

import BackButton from "@/components/astro/back-button.astro";
import ThemeToggle from "@/components/astro/theme-toggle.astro";
import RedirectCheck from "@/components/RedirectCheck";
import { Toaster } from "@/components/ui/sonner";
import Base from "@/layouts/Base.astro";
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Base title={title}>
  <ClientRouter slot="transition" fallback="swap" />

  <RedirectCheck client:load />
  <Toaster
    position="top-center"
    richColors
    client:load
    transition:persist
    transition:persist-props
  />

  <header class="fixed flex w-full justify-between px-4 py-2">
    <BackButton />
    <ThemeToggle />
  </header>

  <main class="container flex grow items-center justify-center px-4">
    <slot />
  </main>
</Base>
