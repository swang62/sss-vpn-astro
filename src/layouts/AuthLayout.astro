---
import "sonner/dist/styles.css";
import BackButton from "@/components/astro/back-button.astro";
import ThemeToggle from "@/components/astro/theme-toggle.astro";
import RedirectCheck from "@/components/RedirectCheck";
import Base from "@/layouts/Base.astro";
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Base title={title}>
  <RedirectCheck client:load />

  <header
    class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-4 py-2"
  >
    <BackButton />
    <ThemeToggle />
  </header>

  <main
    class="relative flex grow items-center justify-center overflow-hidden px-4 py-section-gap-md"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute top-1/2 left-1/2 size-200 -translate-x-1/2 -translate-y-1/2 rounded-full"
      style="background: radial-gradient(circle, color-mix(in srgb, var(--primary) 8%, transparent) 0%, transparent 70%)"
    >
    </div>

    <div class="relative z-10 w-full max-w-100">
      <div
        class="relative overflow-hidden rounded-xl border border-border bg-card p-8"
      >
        <div
          aria-hidden="true"
          class="absolute top-0 left-0 h-px w-full"
          style="background: linear-gradient(90deg, transparent, var(--primary), transparent)"
        >
        </div>
        <slot />
      </div>

      <div
        class="mt-8 flex items-center justify-center gap-6 opacity-50 grayscale transition-all duration-500 hover:opacity-100 hover:grayscale-0"
      >
        <div
          class="flex items-center gap-1.5 font-mono text-[10px] tracking-widest text-muted-foreground"
        >
          <Icon name="lucide:lock" class="size-3.5" />
          ENCRYPTED
        </div>
        <div
          class="flex items-center gap-1.5 font-mono text-[10px] tracking-widest text-muted-foreground"
        >
          <Icon name="lucide:eye-off" class="size-3.5" />
          NO-LOGS
        </div>
        <div
          class="flex items-center gap-1.5 font-mono text-[10px] tracking-widest text-muted-foreground"
        >
          <Icon name="lucide:globe" class="size-3.5" />
          GLOBAL
        </div>
      </div>
    </div>
  </main>
</Base>
