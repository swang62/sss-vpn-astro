---
import RedirectCheck from "@/components/RedirectCheck";
import ThemeToggle from "@/components/ThemeToggle";
import Base from "@/layouts/Base.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Base title={title}>
  <header class="fixed flex justify-end w-full px-4 py-2">
    <ThemeToggle client:load />
    <RedirectCheck client:load />
  </header>

  <main class="container flex items-center justify-center flex-grow px-4 mx-auto">
    <slot />
  </main>
</Base>
