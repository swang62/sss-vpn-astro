---
import { cn } from "@/lib/utils";
---

<header
  class={cn(
    "flex items-center h-16 z-50 sticky top-0 border-b border-border bg-background/80 backdrop-blur-md",
  )}
>
  <div class="container relative flex items-center justify-between w-full">
    <div class="flex w-full gap-6 md:gap-8 lg:gap-10">
      <!-- slot:mobile -->
      <div class="md:hidden">
        <slot name="mobile" />
      </div>

      <a href="/#top" class="items-center hidden space-x-2 md:flex">
        <img
          src="/favicon.ico"
          alt="logo"
          width={32}
          height={32}
          loading="eager"
        />
        <!-- slot:left -->
        <slot name="left" />
      </a>

      <!-- slot:center -->
      <div class="hidden md:flex">
        <slot name="center" />
      </div>
    </div>

    <!-- slot:right  -->
    <slot name="right" />
  </div>
</header>
