---
import { SITE_NAME } from "@/config/constants";
import { cn } from "@/lib/utils";
---

<header
  class={cn(
    "flex items-center h-16 z-50 sticky top-0 border-b border-border bg-background/80 backdrop-blur-md",
  )}
>
  <div class="container flex items-center">
    <!-- slot:mobile -->
    <div class="md:hidden">
      <slot name="mobile" />
    </div>

    <!-- slot:left (logo) -->
    <div class="hidden md:flex flex-1 items-center">
      <a href="/#top" class="flex items-center gap-2">
        <img
          src="/favicon.ico"
          alt="logo"
          width={32}
          height={32}
          loading="eager"
          class="shrink-0"
        />
        <span
          class="font-heading text-xl text-nowrap leading-none translate-y-px"
        >
          {SITE_NAME}
        </span>
      </a>
    </div>

    <!-- slot:center (nav links) -->
    <div class="hidden md:flex flex-1 items-center justify-center">
      <slot name="center" />
    </div>

    <!-- slot:right (actions) -->
    <div class="flex flex-1 items-center justify-end gap-x-4">
      <slot name="right" />
    </div>
  </div>
</header>
