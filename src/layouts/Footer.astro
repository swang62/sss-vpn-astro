    class="container flex w-full items-center justify-start gap-2 md:px-8 xl:px-2"
  >
    <p
      class="text-muted-foreground text-center text-sm leading-loose md:text-left"
    >
      © {year} Built By
      <a
        href="https://github.com/swang62"
        target="_blank"
        rel="noreferrer"
        class="font-medium underline underline-offset-2 ml-1">Me</a
      >
    </p>
    |
    <p
      class="text-muted-foreground text-center text-sm leading-loose md:text-right"
    >
      <a href=`/privacy` class="hover:underline">Privacy Policy</a>
    </p>
  </div>
</footer>
