---
import "@/styles/globals.css";
import Head from "./Head.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={title} />
  </head>
  <body class="bg-background text-foreground">
    <div class="mx-auto px-4 sm:px-6 lg:px-8">
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
