---
import { ThemeToggle } from "@/components/ThemeToggle";
import { setupNewUserProfile } from "@/db/mutations";
import { getProfileById } from "@/db/queries";
import Base from "@/layouts/Base.astro";
import Header from "@/layouts/Header.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;

// Get session data
const { userSession } = Astro.locals;
if (!userSession) {
  Astro.redirect("/login");
  return;
}

// For verified first time users, setup their profile
const isVerified = userSession.emailVerified;
if (isVerified) {
  const userId = userSession.id;
  const profile = await getProfileById(userId);
  if (!profile) {
    await setupNewUserProfile(userId);
    // TODO: also setup vpn access here
  }
}
---

<Base title={title}>
  <Header>
    <!-- <MobileMenu links={links} slot="mobile-menu" client:load /> -->
    <!-- <DesktopMenu links={links} slot="center-header" /> -->

    <div class="flex items-center gap-x-4" slot="right-header">
      <ThemeToggle client:load />
    </div>
  </Header>

  <main class="container mx-auto gap-4 md:gap-8">
    <slot />
  </main>
</Base>
