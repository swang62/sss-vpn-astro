---
import AvatarMenu from "@/components/AvatarMenu";
import DashboardDesktopMenu from "@/components/DashboardDesktopMenu";
import DashboardMobileMenu from "@/components/DashboardMobileMenu";
import DashboardVerify from "@/components/DashboardVerify";
import ThemeToggle from "@/components/ThemeToggle";
import { SITE_NAME } from "@/config/constants";
import { setupNewUser } from "@/db/mutations-user";
import Base from "@/layouts/Base.astro";
import Header from "@/layouts/Header.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
const { pathname } = Astro.url;

// Get session data
const { session, user } = Astro.locals;
if (!session || !user) {
  Astro.redirect("/login");
  return;
}

// For verified first time users, setup their profile
const isVerified = user.emailVerified;
if (isVerified && !user.profile?.stripeCustomerId) {
  await setupNewUser(user);
}
---

<Base title={title}>
  <Header>
    <DashboardMobileMenu current={pathname} slot="mobile" client:load />
    <span class="text-xl text-nowrap md:inline-block" slot="left">
      {SITE_NAME}
    </span>

    <DashboardDesktopMenu current={pathname} slot="center" />

    <div class="flex items-center gap-x-4" slot="right">
      <ThemeToggle client:load />
      <AvatarMenu client:load />
    </div>
  </Header>

  <main class="container gap-4 mx-auto md:gap-8">
    {isVerified ? <slot /> : <DashboardVerify client:load user={user} />}
  </main>
</Base>
