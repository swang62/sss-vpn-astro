---
import ThemeToggle from "@/components/astro/theme-toggle.astro";
import DashboardVerify from "@/components/dashboard/DashboardVerify";
import AvatarMenu from "@/components/header/AvatarMenu";
import DashboardDesktopMenu from "@/components/header/DashboardDesktopMenu";
import DashboardMobileMenu from "@/components/header/DashboardMobileMenu";
import { Toaster } from "@/components/ui/sonner";
import { SITE_NAME } from "@/config/constants";
import { setupNewUser, updateIpAddress } from "@/db/mutations-user";
import Base from "@/layouts/Base.astro";
import Navbar from "@/layouts/Navbar.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
const { pathname } = Astro.url;

// Get session data
const connectingIp = Astro.request.headers.get("cf-connecting-ip");
const astroIp = Astro.clientAddress;
const ip = connectingIp || astroIp;

const { session, user } = Astro.locals;
if (!session || !user) {
  Astro.redirect("/login");
  return;
}

// For verified first time users, setup their profile
const isVerified = user.emailVerified;
if (isVerified) {
  if (!user.profile?.stripeCustomerId) {
    setupNewUser(user, ip);
  } else {
    updateIpAddress(user, ip);
  }
}
---

<Base title={title}>
  <Toaster position="top-center" richColors client:load />

  <Navbar>
    <DashboardMobileMenu pathname={pathname} slot="mobile" client:load />
    <span class="text-xl text-nowrap md:inline-block" slot="left">
      {SITE_NAME}
    </span>

    <DashboardDesktopMenu pathname={pathname} slot="center" />

    <div class="flex items-center gap-x-4" slot="right">
      <ThemeToggle />
      <AvatarMenu session={session} client:load />
    </div>
  </Navbar>

  <main class="container mx-auto flex grow gap-4 pb-8 md:gap-8">
    {isVerified ? <slot /> : <DashboardVerify client:load user={user} />}
  </main>
</Base>
