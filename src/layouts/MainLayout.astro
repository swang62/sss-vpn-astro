---
import { DesktopMenu } from "@/components/DesktopMenu";
import { MobileMenu } from "@/components/MobileMenu";
import { ThemeToggle } from "@/components/ThemeToggle";
import { Button } from "@/components/ui/button";
import { navigationMenuTriggerStyle } from "@/components/ui/navigation-menu";
import Base from "@/layouts/Base.astro";
import Footer from "@/layouts/Footer.astro";
import Header from "@/layouts/Header.astro";
import { MainMenuLink } from "@/lib/types";

const links: MainMenuLink[] = [
  {
    href: "/#about",
    label: "About",
  },
  {
    href: "/#features",
    label: "Features",
  },
  {
    href: "/#pricing",
    label: "Pricing",
  },
  {
    href: "/#faqs",
    label: "FAQs",
  },
];

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Base title={title}>
  <Header>
    <MobileMenu links={links} slot="mobile-menu" client:load />
    <DesktopMenu links={links} slot="center-header" />

    <div class="flex items-center gap-x-4" slot="right-header">
      <ThemeToggle client:load />
      <a
        href="/login"
        class={navigationMenuTriggerStyle({
          className:
            "pr-2 pl-2 bg-transparent hover:bg-transparent hover:text-muted-foreground focus:bg-transparent",
        })}
        data-astro-reload
      >
        Log in
      </a>

      <a href="/signup" data-astro-reload>
        <Button className="rounded-full">Get started</Button>
      </a>
    </div>
  </Header>

  <main class="container mx-auto gap-4 md:gap-8">
    <slot />
  </main>

  <Footer />
</Base>
