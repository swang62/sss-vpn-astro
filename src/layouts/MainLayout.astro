---
import ThemeToggle from "@/components/astro/theme-toggle.astro";
import MainDesktopMenu from "@/components/header/MainDesktopMenu";
import MainLoginButtons from "@/components/header/MainLoginButtons";
import MainMobileMenu from "@/components/header/MainMobileMenu";
import Base from "@/layouts/Base.astro";
import Footer from "@/layouts/Footer.astro";
import Navbar from "@/layouts/Navbar.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Base title={title}>
  <Navbar>
    <MainMobileMenu slot="mobile" client:visible />

    <MainDesktopMenu slot="center" />

    <div class="flex items-center gap-x-4" slot="right">
      <ThemeToggle />
      <!-- <MainAvatarMenu server:defer> -->
      <MainLoginButtons slot="fallback" />
      <!-- </MainAvatarMenu> -->
    </div>
  </Navbar>

  <main class="container mx-auto grow gap-4 md:gap-8">
    <slot />
  </main>

  <script is:inline defer async data-astro-rerun>
    (function (d, t) {
      const BASE_URL = "https://chatwoot.stronglybrewed.dev";
      const g = d.createElement(t),
        s = d.getElementsByTagName(t)[0];
      g.src = BASE_URL + "/packs/js/sdk.js";
      g.async = true;
      s.parentNode.insertBefore(g, s);
      g.onload = function () {
        window.chatwootSettings = {
          darkMode: "auto",
        };
        window.chatwootSDK.run({
          baseUrl: BASE_URL,
          websiteToken: "yUi3b2qGBec28Q5RkANetFEM",
        });
      };
    })(document, "script");
  </script>
  <Footer />
</Base>
