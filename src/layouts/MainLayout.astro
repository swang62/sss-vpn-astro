---
import MainDesktopMenu from "@/components/header/MainDesktopMenu";
import MainMobileMenu from "@/components/header/MainMobileMenu";
import ThemeToggle from "@/components/header/ThemeToggle";
import { Button } from "@/components/ui/button";
import { navigationMenuTriggerStyle } from "@/components/ui/navigation-menu";
import { SITE_NAME } from "@/config/constants";
import Base from "@/layouts/Base.astro";
import Footer from "@/layouts/Footer.astro";
import Navbar from "@/layouts/Navbar.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Base title={title}>
  <Navbar>
    <MainMobileMenu slot="mobile" client:load />
    <span class="text-xl text-nowrap md:inline-block" slot="left">
      {SITE_NAME}
    </span>

    <MainDesktopMenu slot="center" />

    <div class="flex items-center gap-x-4" slot="right">
      <ThemeToggle client:load />
      <a
        href="/login"
        class={navigationMenuTriggerStyle({
          className:
            "pr-2 pl-2 bg-transparent hover:bg-transparent hover:text-muted-foreground focus:bg-transparent",
        })}
      >
        Log in
      </a>
      <a href="/signup">
        <Button className="rounded-full" data-umami-event="get-started"
          >Get started</Button
        >
      </a>
    </div>
  </Navbar>

  <main class="container mx-auto grow gap-4 md:gap-8">
    <slot />
  </main>
  <Footer />
</Base>
