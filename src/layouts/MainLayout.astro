---
import ThemeToggle from "@/components/astro/theme-toggle.astro";
import MainAvatarMenu from "@/components/header/MainAvatarMenu.astro";
import MainDesktopMenu from "@/components/header/MainDesktopMenu";
import MainLoginButtons from "@/components/header/MainLoginButtons";
import MainMobileMenu from "@/components/header/MainMobileMenu";
import Base from "@/layouts/Base.astro";
import Footer from "@/layouts/Footer.astro";
import Navbar from "@/layouts/Navbar.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Base title={title}>
  <Navbar>
    <MainMobileMenu slot="mobile" client:visible />

    <MainDesktopMenu slot="center" />

    <div class="flex items-center gap-x-4" slot="right">
      <ThemeToggle />
      <MainAvatarMenu server:defer>
        <MainLoginButtons slot="fallback" client:load />
      </MainAvatarMenu>
    </div>
  </Navbar>

  <main class="grow">
    <slot />
  </main>

  <Footer />
</Base>
