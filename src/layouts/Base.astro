---
import { PUBLIC_GTM_ID } from "@/config/client";

import BaseHead from "./BaseHead.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead title={title} />
    <slot name="transition" />
  </head>
  <body class="flex min-h-screen flex-col">
    <slot />

    <!-- Analytics scripts, load last -->
    {
      PUBLIC_GTM_ID && (
        <script
          is:inline
          defer
          async
          data-astro-rerun
          src="https://umami.stronglybrewed.dev/script.js"
          data-website-id={PUBLIC_GTM_ID}
        />
      )
    }
  </body>
</html>
