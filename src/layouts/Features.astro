---
import { Icon } from "astro-icon/components";

const features = [
  {
    description:
      "Almost all commercial VPN services are banned or extremely unreliable in China (despite their claims). The fact that this VPN actually works is its biggest feature IMO.",
    icon: "lucide:biceps-flexed",
    title: "It actually works",
  },
  {
    description:
      "Personal customer support from someone who is using the same VPN every day. Any downtime will be addressed immediately.",
    icon: "lucide:heart-handshake",
    title: "Unbeatable customer service",
  },
  {
    description:
      "Everything is hosted on my own private cloud servers. If the server gets banned, I can spin up another one in no time.",
    icon: "lucide:shield-check",
    title: "Resilient against bans",
  },
  {
    description:
      "Supports all desktop and mobile platforms. Latest cutting-edge obfuscation protocols like X-ray, Vless, Vmess, Reality, Trojan, Hysteria, Shadowsocks, and more...",
    icon: "lucide:globe-lock",
    title: "Boring technical details",
  },
];
---

<section id="features" class="py-8 sm:py-16">
  <div class="py-8">
    <div class="container max-w-6xl">
      <div class="flex flex-col items-center text-center">
        <div class="text-gradient mb-6 text-xl font-semibold md:text-2xl">
          Features
        </div>
        <h2 class="font-heading text-3xl md:text-4xl lg:text-[40px]">
          What makes this VPN unique?
        </h2>
      </div>

      <div class="mt-12 grid gap-4 sm:grid-cols-2">
        {
          features.map((feature) => (
            <div class="group bg-background relative overflow-hidden rounded-2xl border p-5 md:p-8">
              <div
                aria-hidden="true"
                class="from-primary/30 absolute inset-0 aspect-video -translate-y-1/2 rounded-full border bg-linear-to-b to-white opacity-25 blur-2xl duration-300 group-hover:-translate-y-1/4 dark:from-gray-300 dark:to-gray-600 dark:opacity-5 dark:group-hover:opacity-10"
              />
              <div class="relative" aria-label={feature.title}>
                <div class="flex flex-row items-center gap-2">
                  <div class="border-border relative mr-1 flex size-12 rounded-xl border shadow-sm *:relative *:m-auto *:size-6">
                    {feature.icon && (
                      <Icon name={feature.icon} class="size-4" />
                    )}
                  </div>
                  <h1>{feature.title}</h1>
                </div>
                <p class="text-muted-foreground mt-6 pb-6">
                  {feature.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
