{
  "name": "sss-vpn",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "astro": "astro",
    "build": "astro check && astro build",
    "build:docker": "pnpm build && docker compose up --build -d",
    "dev": "astro dev",
    "lint": "eslint . --fix",
    "start": "nodemon ./dist/server/entry.mjs",
    "stop": "docker compose down --remove-orphans"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^8.3.4",
    "@astrojs/react": "^3.6.2",
    "@astrojs/tailwind": "^5.1.1",
    "astro": "^4.15.11",
    "nodemon": "^3.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.7.3",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "astro-eslint-parser": "^1.0.3",
    "eslint": "^9.11.1",
    "eslint-plugin-astro": "^1.2.4",
    "eslint-plugin-format": "^0.1.2",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "vite": "^5.4.8"
  },
  "overrides": {
    "@antfu/eslint-config": {
      "prettier-plugin-astro": "$prettier-plugin-astro"
    },
    "yaml-language-server": {
      "prettier": "$prettier"
    }
  }
}
