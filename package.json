{
  "name": "sssvpn",
  "type": "module",
  "version": "1.0.5",
  "scripts": {
    "build": "NODE_ENV=production astro check && export $(cat .env.build) && astro build",
    "build:docker": "pnpm start:docker --build",
    "check": "astro check",
    "db:migrate": "drizzle-kit generate && drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "dev": "astro dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "styles": "prettier --check .",
    "styles:fix": "prettier --write .",
    "logs": "docker compose logs -f",
    "prepare": "husky || true",
    "preview:build": "dotenv -- astro preview",
    "seed": "dotenv -- tsx ./scripts/seed.ts",
    "seed:docker": "pnpm stop && docker volume rm sss-vpn-astro_libsql && docker compose run --entrypoint='' sssvpn pnpm tsx ./scripts/seed.ts",
    "start": "node ./dist/server/entry.mjs",
    "start:docker": "docker compose up -d --remove-orphans",
    "stop": "docker compose down --remove-orphans",
    "studio": "drizzle-kit studio --verbose",
    "studio:docker": "DB_REMOTE=http://localhost:8888 drizzle-kit studio --verbose",
    "test": "vitest run --changed",
    "test:all": "vitest run --typecheck --reporter verbose"
  },
  "dependencies": {
    "@astrojs/node": "^9.4.0",
    "@astrojs/react": "^4.3.0",
    "@hono/zod-validator": "^0.7.2",
    "@hookform/resolvers": "^5.2.1",
    "@iconify-json/lucide": "^1.2.62",
    "@iconify-json/mdi": "^1.2.3",
    "@icons-pack/react-simple-icons": "^13.7.0",
    "@libsql/client": "^0.15.11",
    "@microlink/react-json-view": "^1.27.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-context-menu": "^2.2.15",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-hover-card": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.15",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-toggle-group": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@sentry/astro": "^10.5.0",
    "astro": "^5.12.9",
    "astro-icon": "^1.1.5",
    "astro-seo": "^0.8.4",
    "axios": "^1.11.0",
    "better-auth": "1.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.4",
    "drizzle-zod": "^0.8.3",
    "framer-motion": "^12.23.12",
    "hono": "^4.9.1",
    "hono-pino": "^0.10.1",
    "hono-rate-limiter": "^0.4.2",
    "lucide-react": "^0.539.0",
    "next-themes": "^0.4.6",
    "pino": "^9.8.0",
    "pino-pretty": "^13.1.1",
    "postmark": "^4.0.5",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "redis": "^5.8.0",
    "sonner": "^2.0.7",
    "stripe": "^18.4.0",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "tsx": "^4.20.4",
    "ua-parser-js": "^2.0.4",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.2.1",
    "@astrojs/check": "^0.9.4",
    "@astrojs/sitemap": "^3.4.2",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.33.0",
    "@inox-tools/astro-when": "^1.2.0",
    "@spotlightjs/astro": "^3.2.6",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.2.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "astro-compressor": "^1.1.2",
    "astro-eslint-parser": "^1.2.2",
    "astro-robots-txt": "^1.0.0",
    "dotenv": "^17.2.1",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-format": "^1.0.1",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.1.11",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm lint:fix",
      "pnpm styles:fix"
    ]
  },
  "volta": {
    "node": "22.18.0",
    "pnpm": "10.14.0"
  }
}
