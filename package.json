{
  "name": "sssvpn",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "astro": "astro",
    "build": "NODE_ENV=production astro check --minimumSeverity warning && export $(cat .env.build) && astro build",
    "build:docker": "pnpm start:docker --build",
    "db:migrate": "drizzle-kit generate && drizzle-kit migrate",
    "db:migrate:docker": "docker compose run sssvpn pnpm drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:seed": "dotenv -- tsx ./scripts/seed-local-db.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "astro dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "logs": "docker compose logs -f",
    "prepare": "husky || true",
    "preview": "dotenv -- astro preview",
    "shadcn:add": "pnpm dlx shadcn@latest add",
    "start": "node ./dist/server/entry.mjs",
    "start:docker": "docker compose up -d --remove-orphans",
    "stop": "docker compose down --remove-orphans",
    "test": "vitest run --changed",
    "test:all": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^8.3.4",
    "@astrojs/react": "^3.6.2",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^5.1.2",
    "@hono/zod-validator": "^0.4.1",
    "@hookform/resolvers": "^3.9.1",
    "@iconify-json/lucide": "^1.2.11",
    "@iconify-json/mdi": "^1.2.1",
    "@libsql/client": "^0.14.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-navigation-menu": "^1.2.1",
    "@radix-ui/react-popover": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@sentry/astro": "^8.36.0",
    "astro": "^4.16.8",
    "astro-compressor": "^0.4.1",
    "astro-icon": "^1.1.1",
    "astro-seo": "^0.8.4",
    "axios": "^1.7.7",
    "better-auth": "0.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.27.0",
    "drizzle-orm": "^0.36.0",
    "drizzle-zod": "^0.5.1",
    "framer-motion": "^11.11.10",
    "hono": "^4.6.8",
    "hono-pino": "^0.4.0",
    "hono-rate-limiter": "^0.4.0",
    "lucide-react": "^0.454.0",
    "next-themes": "^0.3.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "postmark": "^4.0.5",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "react": "^18.3.1",
    "react-cookie": "^7.2.2",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "redis": "^4.7.0",
    "sonner": "^1.5.0",
    "stripe": "^17.3.0",
    "swr": "^2.2.5",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.14",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.6.3",
    "ua-parser-js": "2.0.0-rc.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.8.0",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@inox-tools/astro-when": "^0.2.4",
    "@tailwindcss/forms": "^0.5.9",
    "@types/node": "^22.8.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "astro-eslint-parser": "^1.0.3",
    "astro-robots-txt": "^1.0.0",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.13.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-format": "^0.1.2",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "pnpm": {
    "overrides": {
      "prettier": "^3.3.3",
      "prettier-plugin-astro": "^0.14.1"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm lint:fix"
    ]
  },
  "volta": {
    "node": "22.9.0",
    "pnpm": "9.12.1"
  }
}
