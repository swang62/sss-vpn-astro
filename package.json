{
  "name": "sssvpn",
  "type": "module",
  "version": "1.0.5",
  "scripts": {
    "astro": "astro",
    "build": "NODE_ENV=production astro check --minimumSeverity warning && export $(cat .env.build) && astro build",
    "build:docker": "pnpm start:docker --build",
    "db:migrate": "drizzle-kit generate && drizzle-kit migrate",
    "db:migrate:docker": "docker compose run sssvpn pnpm drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:seed": "dotenv -- tsx ./scripts/seed-local-db.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "astro dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "logs": "docker compose logs -f",
    "prepare": "husky || true",
    "preview": "dotenv -- astro preview",
    "shadcn:add": "pnpm dlx shadcn@latest add",
    "start": "node ./dist/server/entry.mjs",
    "start:docker": "docker compose up -d --remove-orphans",
    "stop": "docker compose down --remove-orphans",
    "test": "vitest run --changed",
    "test:all": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^9.4.0",
    "@astrojs/react": "^4.3.0",
    "@astrojs/sitemap": "^3.4.2",
    "@hono/zod-validator": "^0.7.2",
    "@hookform/resolvers": "^5.2.1",
    "@iconify-json/lucide": "^1.2.62",
    "@iconify-json/mdi": "^1.2.3",
    "@libsql/client": "^0.15.10",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.13",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@sentry/astro": "^10.5.0",
    "@tailwindcss/vite": "^4.1.11",
    "astro": "^5.12.9",
    "astro-compressor": "^1.1.2",
    "astro-icon": "^1.1.5",
    "astro-seo": "^0.8.4",
    "axios": "^1.11.0",
    "better-auth": "1.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.4",
    "drizzle-zod": "^0.8.3",
    "framer-motion": "^12.23.12",
    "hono": "^4.9.1",
    "hono-pino": "^0.10.1",
    "hono-rate-limiter": "^0.4.2",
    "lucide-react": "^0.539.0",
    "next-themes": "^0.4.6",
    "pino": "^9.8.0",
    "pino-pretty": "^13.1.1",
    "postmark": "^4.0.5",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.1",
    "react": "^19.1.1",
    "react-cookie": "^8.0.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "redis": "^5.8.0",
    "sonner": "^2.0.7",
    "stripe": "^18.4.0",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.2",
    "ua-parser-js": "^2.0.4",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.2.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@inox-tools/astro-when": "^1.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "@types/node": "^24.2.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "astro-eslint-parser": "^1.2.2",
    "astro-robots-txt": "^1.0.0",
    "dotenv": "^17.2.1",
    "dotenv-cli": "^10.0.0",
    "eslint": "^9.33.0",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-format": "^1.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "sharp": "^0.34.3",
    "tsx": "^4.20.4",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm lint:fix"
    ]
  },
  "volta": {
    "node": "22.18.0",
    "pnpm": "10.14.0"
  }
}
