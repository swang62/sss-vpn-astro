{
  "name": "sssvpn",
  "type": "module",
  "version": "1.0.5",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "astro build",
    "build:docker": "pnpm start:docker --build --force-recreate",
    "check": "astro check",
    "db:migrate": "drizzle-kit generate && drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "dev": "astro dev",
    "gitleaks": "gitleaks detect --source . --config .gitleaks.toml --verbose --no-banner",
    "lint": "biome check --write --unsafe . && prettier --write 'src/**/*.astro'",
    "logs": "docker compose logs -f",
    "prepare": "husky || true",
    "preview": "dotenv -- astro preview",
    "preview:build": "pnpm build && pnpm preview",
    "seed": "dotenv -- tsx ./src/db/scripts/seed.ts",
    "seed:docker": "pnpm stop && docker volume rm sss-vpn-astro_libsql && docker compose run --entrypoint='' sssvpn pnpm tsx ./src/db/scripts/seed.ts",
    "start": "dotenv -- node ./dist/server/entry.mjs",
    "start:docker": "docker compose up -d --remove-orphans",
    "stop": "docker compose down --remove-orphans",
    "studio": "drizzle-kit studio --verbose",
    "studio:remote": "DB_REMOTE=http://localhost:8080 drizzle-kit studio --verbose",
    "test": "vitest run --changed",
    "test:all": "vitest run --typecheck --reporter verbose"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@astrojs/react": "^6.0.1",
    "@better-auth/redis-storage": "^1.6.23",
    "@hono/zod-validator": "^0.8.0",
    "@hookform/resolvers": "^5.4.0",
    "@iconify-json/lucide": "^1.2.116",
    "@iconify-json/mdi": "^1.2.3",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@libsql/client": "^0.17.4",
    "@marsidev/react-turnstile": "^1.5.3",
    "@microlink/react-json-view": "^1.31.22",
    "@paralleldrive/cuid2": "^3.3.0",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@sentry/astro": "^10.63.0",
    "astro": "^7.0.6",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
    "axios": "^1.18.1",
    "better-auth": "1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.28",
    "hono-pino": "^0.10.3",
    "hono-rate-limiter": "^0.5.3",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.23.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postmark": "^4.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.23.0",
    "ua-parser-js": "^2.0.10",
    "unstorage": "^1.17.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/ts-plugin": "^1.10.10",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@spotlightjs/astro": "^3.2.6",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro-compressor": "^1.3.0",
    "astro-robots-txt": "^1.0.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "sonda": "^0.14.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,css}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.astro": [
      "prettier --write"
    ]
  }
}
