{
  "name": "sssvpn",
  "type": "module",
  "version": "1.0.5",
  "scripts": {
    "build": "astro build",
    "build:docker": "pnpm start:docker --build",
    "check": "astro check",
    "db:migrate": "drizzle-kit generate && drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "dev": "astro dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "styles": "prettier --check .",
    "styles:fix": "prettier --write .",
    "logs": "docker compose logs -f",
    "prepare": "husky || true",
    "preview": "dotenv -- astro preview",
    "preview:build": "pnpm build && pnpm preview",
    "seed": "dotenv -- tsx ./src/db/scripts/seed.ts",
    "seed:docker": "pnpm stop && docker volume rm sss-vpn-astro_libsql && docker compose run --entrypoint='' sssvpn pnpm tsx ./src/db/scripts/seed.ts",
    "start": "dotenv -- node ./dist/server/entry.mjs",
    "start:docker": "docker compose up -d --remove-orphans",
    "stop": "docker compose down --remove-orphans",
    "studio": "drizzle-kit studio --verbose",
    "studio:remote": "DB_REMOTE=http://localhost:8888 drizzle-kit studio --verbose",
    "test": "vitest run --changed",
    "test:all": "vitest run --typecheck --reporter verbose"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.2",
    "@astrojs/react": "^5.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@hookform/resolvers": "^5.2.2",
    "@iconify-json/lucide": "^1.2.98",
    "@iconify-json/mdi": "^1.2.3",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@libsql/client": "^0.17.0",
    "@marsidev/react-turnstile": "^1.4.2",
    "@microlink/react-json-view": "^1.31.14",
    "@paralleldrive/cuid2": "^3.3.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/astro": "^10.44.0",
    "astro": "^6.0.6",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
    "axios": "^1.13.6",
    "better-auth": "1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.8",
    "hono-pino": "^0.10.3",
    "hono-rate-limiter": "^0.5.3",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postmark": "^4.0.7",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "ua-parser-js": "^2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/sitemap": "^3.7.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@spotlightjs/astro": "^3.2.6",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro-compressor": "^1.3.0",
    "astro-eslint-parser": "^1.3.0",
    "astro-robots-txt": "^1.0.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-format": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sonda": "^0.11.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm lint:fix",
      "pnpm styles:fix"
    ]
  },
  "volta": {
    "node": "22.18.0",
    "pnpm": "10.14.0"
  }
}
