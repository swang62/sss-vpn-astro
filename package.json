{
  "name": "sss-vpn",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "astro": "astro",
    "build": "astro check && astro build",
    "build:docker": "pnpm build && docker compose up --build -d",
    "dev": "astro dev",
    "lint": "eslint . --fix",
    "logs": "docker compose logs -f",
    "start": "nodemon ./dist/server/entry.mjs",
    "stop": "docker compose down --remove-orphans",
    "seed:prod": "dotenv -v DB_MODE=production -- sh ./build/seed-from-prod.sh"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^8.3.4",
    "@astrojs/react": "^3.6.2",
    "@astrojs/tailwind": "^5.1.1",
    "astro": "^4.15.11",
    "dotenv": "^16.4.5",
    "dotenv-expand": "^11.0.6",
    "hono": "^4.6.3",
    "hono-pino": "^0.3.0",
    "nodemon": "^3.1.7",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^3.7.3",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "astro-eslint-parser": "^1.0.3",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9.11.1",
    "eslint-plugin-astro": "^1.2.4",
    "eslint-plugin-format": "^0.1.2",
    "prettier": "^3.3.3",
    "prettier-plugin-astro": "^0.13.0",
    "vite": "^5.4.8"
  },
  "overrides": {
    "yaml-language-server": {
      "prettier": "$prettier"
    }
  }
}
